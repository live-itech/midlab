# MidLab Configuration
# Copy ke /etc/midlab/config.yaml lalu sesuaikan value-nya
#   sudo mkdir -p /etc/midlab
#   sudo cp config.yaml.example /etc/midlab/config.yaml

database:
  host: "127.0.0.1"
  port: 3306
  user: "midlab"
  password: "GANTI_PASSWORD_ANDA"
  database: "midlab_db"
  pool_size: 10
  pool_recycle: 3600

server:
  host: "0.0.0.0"
  debug: false

result_sender:
  poll_interval: 5
  lis_api_url: "http://localhost:8080/api/results"
  lis_api_key: ""
  retry_max: 3

order_receiver:
  port: 8001

web_console:
  port: 8000

logging:
  level: "INFO"
  max_bytes: 10485760   # 10 MB
  backup_count: 5
